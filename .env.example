# ── aigency-os environment variables ─────────────────────────────
# Copy to .env.local and fill in real values.
# NEVER commit .env.local — it is git-ignored.

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=aigency
POSTGRES_PASSWORD=aigency_dev
POSTGRES_DB=aigency

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Application ──────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── API Keys (fill in production secrets) ────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# JWT_SECRET=

# ── Service Ports (defaults shown — override if needed) ──────────
# PAPERCLIP_API_PORT=3001
# BMAD_PORT=3010
# PAUL_PORT=3011
# GSTACK_PORT=3012
# PLANNOTATOR_PORT=3013
# AEGIS_PORT=3014
# DENCHCLAW_PORT=3015
# GBRAIN_PORT=3016
# HCOM_API_PORT=3007
