# ─── Aigency OS Environment Variables ────────────────────────────────────────
# Copy to .env and fill in your values.

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# Auth — CHANGE THESE IN PRODUCTION
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Admin account (seeded on first run)
ADMIN_EMAIL=admin@aigency.os
ADMIN_PASSWORD=your-secure-password
ADMIN_NAME=Antonio Reid

# Database
AUTH_DB_PATH=./data/auth.db

# Frontend (path to built static files)
FRONTEND_PATH=./apps/web/dist

# CORS (set to your domain in production)
# CORS_ORIGIN=https://yourdomain.com

# Service URLs (for frontend — set in Vite build)
# VITE_API_URL=https://yourdomain.com
# VITE_PAPERCLIP_URL=https://yourdomain.com
# VITE_DENCHCLAW_URL=https://yourdomain.com/api/denchclaw
# VITE_HCOM_URL=https://yourdomain.com/api/hcom
# VITE_GBRAIN_URL=https://yourdomain.com/api/gbrain
# VITE_AEGIS_URL=https://yourdomain.com/api/aegis
# VITE_PLANNOTATOR_URL=https://yourdomain.com/api/plannotator
