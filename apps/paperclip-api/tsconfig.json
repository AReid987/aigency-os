{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "paths": {
      "@aigency-os/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@aigency-os/shared-types/*": ["../../packages/shared-types/src/*"]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/unified-server.ts"
  ],
  "references": [
    {
      "path": "../../packages/shared-types"
    }
  ]
}
